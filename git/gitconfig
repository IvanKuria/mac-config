[user]
	email = ivankuria7@gmail.com
	name = Ivan Kuria

[core]
	compression = 9
	whitespace = error
	preloadindex = true	

[advice]
	addEmptyPathspec = false
	pushNonFastForward = false
	statusHints = false

[status]
	branch = true
	showStash = true
	showUntrackedFiles = all

[diff]
	context = 3
	renames = copies
	interHunkContext = 10

[pager]
	diff = dif-so-fancy | $PAGER

[dif-so-fancy]
	markEmptyLines = false

[color "diff"]
	meta       = black bold
	frag       = magenta
	context    = white
	whitespace = yellow reverse
	old        = red

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
